<!DOCTYPE html>
<html>
    <head>
        <title>Authors Inventory</title>
    <%- include('styles') %>
    </head>
<body>
    <%- include('sidebar') %>
    <div style="margin-right:15%">
        <div class="w3-container w3-teal">
                <p><a href="/"><img src="/images/icon.png" style="float:left" alt="Book Inventory App" height="42" width="42"></a></p><h1>Authors</h1>
        </div></br>
        <div class="w3-container">
            <% if ( locals.authors && typeof(locals.authors) == 'object' && locals.authors.length >0 ) {%>
            <table align="center">
                <caption><h2>Authors</h2></caption>
                <tr>
                    <th>Full name</th>
                    <th>Birth Date</th>
                    <th>Country of birth</th>
                    <th>Available actions</th>
                </tr>

                <% authors.forEach(author => { %>
                <tr>
                    <td><%= author.fullname %></td>
                    <td><%= author.birthdate.toISOString().split('T')[0] %></td>
                    <td><%= author.country %></td>
                    <td>
                        <button onclick="location.href='/update/author/?fullname=<%= encodeURIComponent(author.fullname) %>&birthDate=<%= author.birthdate.toISOString().split('T')[0] %>&country=<%= author.country %>'" class="button-class">Update</button>
                        <form action="/delete/author" method="POST">
                            <input type="hidden" name="fullname" id="fullname" value="<%= encodeURIComponent(author.fullname) %>" required>
                            <button type="submit" onclick="return confirm('This will remove all books of author <%= author.fullname %>. Are you sure?')" class="button-class">Delete</button>
                        </form>
                    </td>
                </tr>
                <%}); %>
            </table>
            </br>
            <div align="center">
                <button onclick="location.href='/new/author'" class="button-class">Create a new author</button>
                <button onclick="location.href='/authors'" class="button-class">List all authors</button>
                <button onclick="location.href='/search/byauthor'" class="button-class">Search by author</button>
            </div>
        </div>
            <%} else if ( locals.error ) { %>
        <div align="center">
            <h4>There was an error: <%= error %></h4>
            <div><button onclick="history.back()" class="button-class">Go Back</button></div>
            <%} else {%>
            <h4>There are no authors defined.</h4>
            <div><button onclick="location.href='/new/author'" class="button-class">Create a new author</button></div>
        </div>
            <%}; %>
    </div>
</body>
</html>