<!-- views/creator.ejs -->
<!DOCTYPE html>
<html>
  <head>
    <title>Create new <%= by %></title>
  </head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
<body>
  <%- include('sidebar') %>
  <div style="margin-right:15%">
    <div class="w3-container w3-teal">
      <h1>Create new <%= by %></h1>
    </div></br>
    <div class="w3-container">
      <form action="/new/<%= by.replace(/\s/g, "") %>" method="POST">
        <% if (locals.by == "author") { %>
        <label for="fullname">Full name: </label>
        <input type="text" name="fullname" id="fullname" required>
        <label for="birthdate">Birth date: </label>
        <input type="date" name="birthdate" id="birthdate" required>
        <label for="country">Country: </label>
        <input type="text" name="country" id="country" required>
        <% } else if (locals.by == "publish date") { %>
        <label for="min">From: </label>
        <input type="date" name="min" id="min" required>
        <label for="max">To: </label>
        <input type="date" name="max" id="max" required>
        <% } else { %>
        <label for="<%= by %>"><%= by.toUpperCase() %>: </label>
        <input type="text" name="<%= by %>" id="<%= by %>" required>
        <% } %>
        <button type="submit">Create
        </button>
      </form>
    </div>
  </div>
</body>
</html>