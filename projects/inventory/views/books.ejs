<!-- views/createUser.ejs -->
<!DOCTYPE html>
<html>
    <head>
    <% if ( locals.by ) {%>
        <title>Books by <%= by %></title>
    <% } else { %>
        <title>Book Inventory</title>
    <% } %>
    </head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
<body>
    <%- include('sidebar') %>
    <div style="margin-right:15%">
        <div class="w3-container w3-teal">
            <% if ( locals.by ) {%>
                <h1>Books by <%= by %></h1>
            <% } else { %>
                <h1>Books Inventory</h1>
            <% } %>        
        </div></br>
        <div class="w3-container">
            <% if ( locals.books && locals.books.length > 0 ) {%>
            <table>
                <caption><h2>Books</h2></caption>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Publish Date</th>
                    <th>Genre</th>
                    <th>Price per unit</th>
                </tr>
                <% books.forEach(book => { %>
                <tr>
                    <td><%= book.title %></td>
                    <td><%= book.author %></td>
                    <td><%= book.publishdate.toISOString().split('T')[0] %></td>
                    <td><%= book.genre %></td>
                    <td><%= book.price %> €</td>
                </tr>
                <%}); %>
            </table>
            </br>
            <div>
                <button onclick="location.href='/new/book'" class="button-class">Create a new book</button>
                <button onclick="location.href='/'" class="button-class">List all book</button>
                <button onclick="location.href='/search/bytitle'" class="button-class">Search by title</button>
                <button onclick="location.href='/search/byauthor'" class="button-class">Search by author</button>
                <button onclick="location.href='/search/bygenre'" class="button-class">Search by genre</button>
                <button onclick="location.href='/search/bypublishdate'" class="button-class">Search by publish date</button>
                <button onclick="location.href='/search/byprice'" class="button-class">Search by price</button>
            </div>
                <%} else if ( locals.error ) { %>
                <h4>There was an error: <%= error %></h4>
                <div><button onclick="history.back()" class="button-class">Go Back</button></div>
                <%} else {%>
                <h4>There are no books defined matching critetia.</h4>
                <div><button onclick="location.href='/new/book'" class="button-class">Create a new book</button></div>
                <div><button onclick="history.back()" class="button-class">Go Back</button></div>
                <%}; %>
        </div>
    </div>
</body>
</html>